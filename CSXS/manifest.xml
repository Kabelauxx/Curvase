<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest Version="11.0" ExtensionBundleId="com.curvase.bezier-editor"
    ExtensionBundleVersion="1.0.0"
    ExtensionBundleName="Curvase"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
        <Extension Id="com.curvase.bezier-editor.panel" Version="1.0" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="AEFT" Version="[15.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="11.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.curvase.bezier-editor.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./MainScript.jsx</ScriptPath>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Curvase</Menu>
                    <Geometry>
                        <Size>
                            <Height>580</Height>
                            <Width>400</Width>
                        </Size>
                        <MaxSize>
                            <Height>900</Height>
                            <Width>600</Width>
                        </MaxSize>
                        <MinSize>
                            <Height>400</Height>
                            <Width>300</Width>
                        </MinSize>
                    </Geometry>
                </UI>
                <CEFCommandLine>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
            </CEFCommandLine>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
